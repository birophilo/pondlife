# Copy to .env and adjust. Required for the FastAPI app (JWT signing).
JWT_SECRET_KEY=replace-with-a-long-random-string

# Postgres (docker-compose). Users table lives here; omit if you set DATABASE_URL.
POSTGRES_USER=pondlife
POSTGRES_PASSWORD=your_password_here
POSTGRES_DB=pondlife

# Optional: full URL (overrides POSTGRES_*). Default uses psycopg2 from POSTGRES_*.
# DATABASE_URL=postgresql+psycopg2://pondlife:your_password_here@localhost:5432/pondlife
